openhands {
	# Protect all routes with forward_auth
	# Replace 'auth-service:9091' with your actual auth provider (e.g., Authelia or Authentik)
	forward_auth auth-service:9091 {
		uri /api/verify?rd=https://auth.example.com/
		copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
	}

	# Forward /handholder* to localhost:3001 with prefix stripped
	handle /handholder* {
		reverse_proxy localhost:3001
	}

	# Forward all other requests to localhost:3000
	handle {
		reverse_proxy localhost:3000
	}

	# If localhost:3000 is unreachable (502 or 503), redirect to /handholder
	handle_errors {
		@gateway_error {
			expression {err.status_code} == 502 || {err.status_code} == 503
			not path /handholder*
		}
		redir @gateway_error /handholder
	}
}
