# API Keys for transcription and post-processing
# Copy this file to '.env' and fill in your keys.

# Hugging Face API Key (if using HF transcriber)
HF_API_KEY="your_huggingface_api_key_here"

# Gemini API Key (if using Gemini post-processor directly)
GEMINI_API_KEY="your_gemini_api_key_here"

# OpenRouter API Key (if using OpenRouter OpenAI-compatible post-processor)
# Make sure to update config.toml to use provider="openai_compatible"
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# General OpenAI API Key (if using OpenAI directly)
# OPENAI_API_KEY="your_openai_api_key_here"
